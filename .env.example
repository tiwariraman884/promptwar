# ─── GreenStep India — Environment Variables ───
# Copy this to .env.local and fill in your values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# ─── Supabase (Auth + Database) ───
# Get these from https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Google Maps ───
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=

# ─── Google Gemini AI (Scanner + AI Coach) ───
GEMINI_API_KEY=

# ─── Anthropic (optional, legacy AI) ───
NEXT_PUBLIC_ANTHROPIC_API_KEY=

# ─── PostHog Analytics (optional) ───
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── External Emission APIs (optional) ───
CLIMATIQ_API_KEY=
EMISSIONS_DEV_API_URL=

# ─── Upstash Redis (Rate Limiting) ───
# Get these from https://console.upstash.com → Redis → your database
UPSTASH_REDIS_REST_URL=https://still-grouse-38446.upstash.io
UPSTASH_REDIS_REST_TOKEN=ApYuAAIgcDGxMiBiK9O3Cfl8sfh_p_lwyWz0-SbGMx436en4pfBtrg

# ─── Rate Limit Configuration (optional — sensible defaults used) ───
# RATE_LIMIT_ANON_MAX=20
# RATE_LIMIT_ANON_WINDOW_S=60
# RATE_LIMIT_AUTH_MAX=100
# RATE_LIMIT_AUTH_WINDOW_S=60
# RATE_LIMIT_AI_MAX=10
# RATE_LIMIT_AI_WINDOW_S=60
# RATE_LIMIT_SENSITIVE_MAX=5
# RATE_LIMIT_SENSITIVE_WINDOW_S=900

# ─── App URL (for SEO/sitemap) ───
NEXT_PUBLIC_APP_URL=https://promptwar-orpin.vercel.app
